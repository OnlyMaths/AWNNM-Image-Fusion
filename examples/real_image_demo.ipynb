# Real Image Fusion using Adaptive WNNM

```python
import torch
from PIL import Image
import matplotlib.pyplot as plt
from awnnm_fusion import adaptive_wnnm_fusion

# Load your test images (change paths)
ir_path = "../test_images/ir_example.png"
vi_path = "../test_images/vi_example.png"

I1 = torch.from_numpy(np.array(Image.open(ir_path).convert('L'))).float() / 255.0
I2 = torch.from_numpy(np.array(Image.open(vi_path).convert('L'))).float() / 255.0

print(f"Image shape: {I1.shape}")

# Fuse
fused = adaptive_wnnm_fusion(I1, I2, lambda_reg=0.055, max_iter=25)

# Display
fig, axes = plt.subplots(1, 3, figsize=(15, 5))
axes[0].imshow(I1, cmap='gray'); axes[0].set_title('Source 1 (IR)')
axes[1].imshow(I2, cmap='gray'); axes[1].set_title('Source 2 (VI)')
axes[2].imshow(fused, cmap='gray'); axes[2].set_title('Fused Image (AWNNM)')

plt.tight_layout()
plt.show()
